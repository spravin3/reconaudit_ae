# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real keys.

# ── DuckDB ────────────────────────────────────────────────────────────────────
DUCKDB_PATH=reconaudit.duckdb

# ── Audit agent provider config ───────────────────────────────────────────────
# Three env vars control the LLM provider. Only change what you need.
#
# OPTION 1: OpenRouter (default) — one key, access to every model
#   Sign up: https://openrouter.ai → Dashboard → Keys → Create Key
OPENROUTER_API_KEY=your-openrouter-key-here
AUDIT_BASE_URL=https://openrouter.ai/api/v1
AUDIT_KEY_ENV=OPENROUTER_API_KEY

# OPTION 2: Switch model while staying on OpenRouter — just change AUDIT_MODEL
#   Gemini (default):  google/gemini-2.0-flash-001
#   Gemini Pro:        google/gemini-1.5-pro
#   Claude Haiku:      anthropic/claude-3.5-haiku
#   Claude Sonnet:     anthropic/claude-3.5-sonnet
#   Llama:             meta-llama/llama-3.3-70b-instruct
AUDIT_MODEL=google/gemini-2.0-flash-001

# OPTION 3: Anthropic native API (no OpenRouter)
#   Get key: https://console.anthropic.com → API Keys
# ANTHROPIC_API_KEY=sk-ant-...
# AUDIT_BASE_URL=https://api.anthropic.com/v1
# AUDIT_KEY_ENV=ANTHROPIC_API_KEY
# AUDIT_MODEL=claude-3-5-haiku-20241022

# OPTION 4: OpenAI native API
#   Get key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# AUDIT_BASE_URL=https://api.openai.com/v1
# AUDIT_KEY_ENV=OPENAI_API_KEY
# AUDIT_MODEL=gpt-4o-mini
